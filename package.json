    "dotenv": "^17.2.3",
    "ecpair": "^2.1.0",
    "ed25519-hd-key": "^1.3.0",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "ethers": "^6.8.0",
    "fast-json-patch": "^3.1.1",
    "ffmpeg-static": "^5.3.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.542.0",
    "next": "^14.0.0",
    "openai": "^4.77.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "4.2.67",
    "playwright-core": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^10.2.0",
    "runelib": "^1.0.7",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.3.3",
    "tailwindcss-animate": "^1.0.7",
    "tiny-secp256k1": "^2.2.4",
