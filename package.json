{
  "name": "qubeagent-frontend",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:check": "next lint --max-warnings=0",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:embed-policy": "node scripts/verify-embed-policy.mjs",
    "check:embed-headers": "node scripts/check-embed-headers.mjs",
    "kb:reembed": "bash scripts/reembed-kb.sh",
    "setup-marketa": "echo '🔧 Setting up Marketa database tables...' && psql $SUPABASE_URL -f scripts/setup-marketa-tables.sql",
    "setup-marketa-simple": "echo '🔧 Setting up Marketa database tables (simple version)...' && psql $SUPABASE_URL -f scripts/setup-marketa-tables-simple.sql",
    "type-check": "tsc --noEmit",
    "test": "vitest --config vitest.config.mjs run",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:ci": "vitest --config vitest.config.mjs run --coverage",
    "test:crm": "vitest --config vitest.config.mjs run tests/crm-integration.test.ts",
    "build:packages": "npm run build --workspace=packages/smarttriad",
    "aa:install": "npm --prefix services/aa-api install",
    "aa:dev": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/aa-api run dev",
    "aa:build": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/aa-api run build",
    "aa:start": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/aa-api run start",
    "browser:smoke": "npm --prefix services/aa-api run build && node scripts/browser-smoke.mjs",
    "browser:verify": "npm --prefix apps/metame-runtime-shell run typecheck && npm test -- --run tests/browser-contracts.test.ts && npm run browser:smoke",
    "wallet:install": "npm --prefix services/agentiq-wallet install",
    "wallet:dev": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/agentiq-wallet run dev",
    "wallet:build": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/agentiq-wallet run build",
    "wallet:start": "DOTENV_CONFIG_PATH=../../.env.local npm --prefix services/agentiq-wallet run start",
    "deploy:qct-runes": "node scripts/deploy-qct-runes.js",
    "deploy:qct-erc20": "hardhat run scripts/deploy-qct-erc20.js",
    "deploy:qct-spl": "node scripts/deploy-qct-spl.js",
    "deploy:qct-reserve": "hardhat run scripts/deploy-qct-reserve.js",
    "deploy:acl-claim": "hardhat run scripts/deploy-acl-claim.js"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.40-alpha.7",
    "@ag-ui/langgraph": "0.0.19",
    "@atheonxyz/verity": "^0.3.2-alpha",
    "@autonomys/auto-drive": "^1.6.4",
    "@autonomys/auto-utils": "^1.6.4",
    "@copilotkit/react-core": "^1.50.0",
    "@copilotkit/react-ui": "^1.50.0",
    "@copilotkit/runtime": "^1.50.0",
    "@copilotkit/shared": "^1.50.0",
    "@dfinity/agent": "^3.2.6",
    "@dfinity/candid": "^3.2.6",
    "@dfinity/identity": "^3.4.2",
    "@dfinity/identity-secp256k1": "^3.4.3",
    "@dfinity/principal": "^3.2.6",
    "@fioprotocol/fiosdk": "^1.10.2",
    "@metame/aa-client": "workspace:*",
    "@metame/browser-contracts": "workspace:*",
    "@metame/contracts": "workspace:*",
    "@metame/iframe-bridge": "workspace:*",
    "@mysten/sui": "^2.17.0",
    "@mysten/walrus": "^1.1.7",
    "@napi-rs/canvas": "^0.1.86",
    "@noble/ed25519": "1.7.3",
