    "@types/chai": "^4.3.20",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.25",
    "@types/react": "^18.2.24",
    "@types/react-dom": "^18.2.8",
    "autoprefixer": "^10.4.23",
    "chai": "^4.5.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "hardhat": "^2.26.3",
    "hardhat-gas-reporter": "^2.3.0",
    "pdf-parse": "^1.1.1",
    "pm2": "^6.0.10",
    "postcss": "^8.4.31",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  }
}
