  "template_registry_interface": {
    "description": "TemplateRegistry service for runtime template lookup and rendering",
    "methods": {
      "getTemplate": {
        "signature": "(templateId: string) => TemplateDefinition | null",
        "description": "Get template definition by ID"
      },
      "selectTemplate": {
        "signature": "(context: SelectionContext) => string",
        "description": "Select best template based on user intent, device, content mix",
        "context_schema": {
          "userIntent": "string",
          "device": "mobile | tablet | desktop",
          "contentMix": "string",
          "realm": "string?",
          "taskState": "string?"
        }
      },
      "renderTemplate": {
        "signature": "(templateId: string, bindings: object) => ReactElement",
        "description": "Render template component with data bindings"
      }
    }
  },
  "copilot_integration": {
    "tool_registration": {
      "description": "Register all template tools with CopilotKit runtime",
      "pattern": "dynamic",
      "code_example": "templates.forEach(t => copilotRuntime.registerAction(t.copilot_tool_spec))"
    },
    "state_sync": {
      "description": "Sync template selection and bindings via STATE_DELTA",
      "fields": [
        "/liquidUI/selectedTemplateId",
        "/liquidUI/templateBindings"
      ]
    },
    "selection_strategy": {
      "description": "Copilot uses template selection policy from knyt_liquid_ui_template_pack.json",
      "priority_order": [
        "user_intent",
        "content_mix",
        "realm",
        "device",
        "task_state",
        "business_goal"
      ]
    }
  },
  "implementation_notes": {
    "stage_1_limitations": [
