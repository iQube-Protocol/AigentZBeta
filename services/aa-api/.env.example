# --- Required ---
PORT=8080
AA_JWT_SECRET=replace-with-long-random-secret

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=assets

# iQube Registry
REGISTRY_ENDPOINT=https://registry.example/api
REGISTRY_API_KEY=replace-with-registry-key

# x402 facilitator
X402_FACILITATOR_ENDPOINT=https://facilitator.example/x402/submit
X402_SIGNING_PRIVATE_KEY=replace-with-hex-or-pem
X402_CALLBACK_PUBLIC_BASE=https://agency.example

# CORS
CORS_ORIGIN=http://localhost:3000

# Browserbase
BROWSERBASE_API_KEY=replace-with-browserbase-api-key
BROWSERBASE_PROJECT_ID=replace-with-browserbase-project-id
BROWSERBASE_API_BASE_URL=https://api.browserbase.com
BROWSERBASE_REGION=us-east-1
BROWSERBASE_KEEP_ALIVE=true
BROWSERBASE_PROXIES=false
BROWSERBASE_SESSION_TIMEOUT_SECONDS=1800
