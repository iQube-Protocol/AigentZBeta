# --- Required ---
PORT=8080
AA_JWT_SECRET=changeme-aa-jwt-secret

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=assets
SUPABASE_JWT_SECRET=changeme-supabase-jwt-secret

# iQube Registry
REGISTRY_ENDPOINT=https://registry.example/api
REGISTRY_API_KEY=replace-with-registry-key

# x402 facilitator
X402_FACILITATOR_ENDPOINT=#https://facilitator.example/x402/submit
X402_SIGNING_PRIVATE_KEY=#replace-with-hex-or-pem
X402_CALLBACK_PUBLIC_BASE=#https://agency.example

# CORS
CORS_ORIGIN=#http://localhost:3000
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
X402_AUTOSUBMIT=true
