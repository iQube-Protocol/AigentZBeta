# --- Required ---
PORT=8080
AA_JWT_SECRET=replace-with-long-random-secret

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
