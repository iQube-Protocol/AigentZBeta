  "template_selection_policy": {
    "inputs": [
      "user_intent",
      "device",
      "content_mix",
      "realm",
      "attention_budget",
      "ownership_state",
      "business_goal",
      "task_state"
    ],
    "priority_order": [
      "user_intent",
      "content_mix",
      "realm",
      "device",
      "task_state",
      "business_goal",
      "attention_budget"
    ],
    "rules": [
      {
        "when": {
          "user_intent": [
            "browse",
            "discover"
          ],
          "content_mix": [
            "mixed",
            "mostly_portrait"
          ]
        },
        "choose_template": "knyt:drawer_grid_v1",
        "why": "Fast browsing with fixed viewport; opens immersive viewers via drawers/modals."
      },
      {
        "when": {
          "user_intent": [
            "character_deep_dive",
            "cover_art",
            "page_review"
          ],
          "content_mix": [
            "portrait_focus"
          ]
        },
        "choose_template": "knyt:dual_poster_stage_v1",
        "why": "90% height portrait stage + optional secondary poster; no page scroll."
      },
      {
        "when": {
          "user_intent": [
            "watch",
            "immersive_review"
          ],
          "content_mix": [
            "motion_focus",
            "landscape_focus"
          ]
        },
        "choose_template": "knyt:motion_stage_v1",
        "why": "Large landscape motion stage with copilot overlay and action rail."
      },
      {
        "when": {
          "user_intent": [
            "questing",
            "ascension",
            "earn_rewards"
          ],
          "content_mix": [
            "mixed"
          ],
          "task_state": [
            "active",
            "needs_guidance"
          ]
        },
        "choose_template": "knyt:quest_hud_hub_v1",
        "why": "Optimized for tasks, rewards, referrals, and Order ascension while keeping content in a fixed stage."
      },
      {
        "when": {
          "user_intent": [
            "bridge_real_to_lore",
            "realm_navigation"
          ],
          "content_mix": [
            "mixed"
          ],
          "realm": [
            "terra",
            "metaterra_or"
          ]
        },
        "choose_template": "knyt:realm_bridge_map_v1",
        "why": "Makes Terra↔DigiTerra↔metaTerra/or transitions explicit and actionable."
      }
    ],
    "outputs": [
      "template_id",
      "drawer_mode",
      "wallet_ui"
    ],
    "drawer_rules": [
      {
        "when": {
          "user_intent": [
            "claim",
            "check_balance",
            "quick_status",
            "confirm"
          ]
        },
        "choose_drawer_mode": "narrow",
        "mount_wallet_ui": [
          "wallet_card.balance",
          "wallet_card.reward_claim"
        ],
        "why": "Glance + tap actions without blocking content."
      },
      {
        "when": {
          "user_intent": [
            "unlock",
            "purchase",
            "send",
            "request",
            "invite",
            "referral_manage",
            "permissions"
          ]
        },
        "choose_drawer_mode": "wide",
        "mount_wallet_ui": [
          "wallet_modal.checkout"
        ],
        "why": "Multi-step flows need wide drawer."
      },
      {
        "when": {
          "task_state": [
            "active",
            "needs_guidance"
          ]
        },
        "choose_drawer_mode": "narrow",
        "mount_wallet_ui": [
          "wallet_card.task_step"
        ],
        "why": "Keep next action visible while browsing."
      }
    ]
  },
