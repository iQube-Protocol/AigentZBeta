{
  "schema_version": "knyt.liquid_ui_template_pack.v0.2",
  "generated_at": "2025-12-18",
  "domain": "knyt",
  "purpose": "Liquid UI templates for KNYT Codex (metaKnyts) using SmartMedia/Smart Content selection rules. Fixed-viewport layouts (no page scrolling) with optional scrolling inside modals. Adds Copilot Drawer (narrow/wide) wallet surface integration.",
  "sources": {
    "content_modal_reference": "https://dev-beta.aigentz.me/content/demo",
    "notes": [
      "Modal/card families referenced from Smart Content Demo: hero short (66vh), poster2, poster3, carousel3, carousel4, thumbnail6, thumbnailRect, compound, compound1/2, iframe, featured, standard, compact, plus mobile variants."
    ]
  },
  "design_constraints": {
    "avoid_page_scroll": true,
    "allow_scroll_in_modals": true,
    "copilot_overlay_policy": {
      "modes": [
        "overlay",
        "docked",
        "collapsed"
      ],
      "default": "overlay",
      "z_layer": "modal",
      "can_hide_for_immersion": true
    },
    "realm_model": {
      "codex": "KNYT Codex",
      "dimensions": {
        "DigiTerra": "In‑world lunapunk counter‑world (lore/immersive).",
        "Terra": "Real‑world bridge (updates, announcements, news).",
        "metaTerra/or": "Convergence realm (utopia metaTerra vs dystopia metaTerror)."
      }
    }
  },
