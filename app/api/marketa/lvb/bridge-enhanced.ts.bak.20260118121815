        make_config: hasMakeIntegration ? {
          enabled: true,
          webhook_configured: true
        } : {
          enabled: false,
          setup_required: true
        }
      }
    };
  },

  // ========================================================================
  // PACK MANAGEMENT (WPP)
  // ========================================================================
  'pack_queue': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { status = 'submitted', limit = 50, offset = 0 } = body;

    const { data: packs, error } = await supabase
      .from('marketa_pack_workflows')
      .select(`
        id,
        pack_id,
        status,
        current_stage,
        created_at,
        submitted_at,
        reviewed_at,
        approved_at,
        pack_content,
        review_feedback
      `)
      .eq('tenant_id', context.tenantId)
      .in('status', status === 'all' ? ['draft', 'submitted', 'review', 'approved', 'rejected', 'published'] : [status])
      .order('created_at', { ascending: false })
      .range(offset, offset + limit - 1);

    if (error) throw error;

    return {
      success: true,
      packs: packs || [],
      total: packs?.length || 0
    };
  },

  'pack_detail': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { packId } = body;

    if (!packId) {
      throw new Error('Pack ID is required');
    }

    const { data: pack, error } = await supabase
      .from('marketa_pack_workflows')
      .select(`
        *,
        created_by_persona:crm_personas!created_by_persona_id(
          display_name, email
        ),
        reviewed_by_persona:crm_personas!reviewed_by_persona_id(
          display_name, email
        ),
        approved_by_persona:crm_personas!approved_by_persona_id(
          display_name, email
        )
      `)
      .eq('pack_id', packId)
      .eq('tenant_id', context.tenantId)
      .single();

    if (error) throw error;

    return {
      success: true,
      pack
    };
  },

  'approve_pack': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { packId, approved } = body;

    if (!packId) {
      throw new Error('Pack ID is required');
    }

    const updateData: any = {
      status: approved ? 'approved' : 'rejected',
      current_stage: approved ? 'publishing' : 'creation',
      reviewed_by_persona_id: context.personaId,
      reviewed_at: new Date().toISOString()
    };

    if (approved) {
      updateData.approved_by_persona_id = context.personaId;
      updateData.approved_at = new Date().toISOString();
    }

    const { data: pack, error } = await supabase
      .from('marketa_pack_workflows')
      .update(updateData)
      .eq('pack_id', packId)
      .eq('tenant_id', context.tenantId)
      .select()
      .single();

    if (error) throw error;

    return {
      success: true,
      pack,
      message: approved ? 'Pack approved and ready for publishing' : 'Pack rejected. Please review feedback.'
    };
  },

