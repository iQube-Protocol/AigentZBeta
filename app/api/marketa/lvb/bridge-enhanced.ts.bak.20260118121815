  'config': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    // Get tenant configuration including Make/webhook setup
    const { data: tenantConfig, error } = await supabase
      .from('crm_tenants')
      .select(`
        id,
        name,
        type,
        settings,
        marketa_tenant_campaign_configs!inner(
          campaign_id,
          publishing_mode,
          make_webhook_url,
          status
        )
      `)
      .eq('id', context.tenantId)
      .single();

    if (error) throw error;

    // Check if Make is configured
    const hasMakeIntegration = tenantConfig.marketa_tenant_campaign_configs.some(
      (config: any) => config.publishing_mode === 'make' && config.make_webhook_url
    );

    return {
      success: true,
      config: {
        tenant_id: context.tenantId,
        persona_id: context.personaId,
        role: context.role,
        permissions: context.permissions,
        tenant_name: tenantConfig.name,
        tenant_type: tenantConfig.type,
        feature_flags: {
          custom_campaigns: true,
          sequence_campaigns: true,
          partner_rewards: true,
