    const { data: newCampaign, error } = await supabase
      .from('marketa_campaigns')
      .insert({
        tenant_id: context.tenantId,
        name: campaign.name,
        description: campaign.description,
        campaign_type: 'custom',
        status: 'draft',
        primary_cta: campaign.primaryCta,
        secondary_cta: campaign.secondaryCta,
        created_by_persona_id: context.personaId,
        metadata: {
          proposed_by: context.personaId,
          proposal_date: new Date().toISOString(),
          ...campaign.metadata
        }
      })
      .select()
      .single();

    if (error) throw error;

    // Log the proposal
    await supabase.from('marketa_lvb_sync_tracking').insert({
      tenant_id: context.tenantId,
      sync_type: 'campaign_proposal',
      source_id: newCampaign.id,
      sync_direction: 'lvb_to_agq',
      sync_status: 'success',
      data_payload: { campaign: newCampaign, proposedBy: context.personaId }
    });

    return {
      success: true,
      campaign: newCampaign,
      message: 'Campaign proposed and awaiting approval'
    };
  },

