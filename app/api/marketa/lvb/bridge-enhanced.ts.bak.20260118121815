  'campaign_catalog': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { includeJoined = true, includeAvailable = true, campaignType } = body;

    let query = supabase
      .from('marketa_campaigns')
      .select(`
        *,
        marketa_multi_tenant_campaigns!inner(
          participating_tenants,
          deployment_status
        )
      `);

    // Filter by campaign type if specified
    if (campaignType) {
      query = query.eq('campaign_type', campaignType);
    }

    // Get available campaigns (not joined yet)
    let availableCampaigns = [];
    if (includeAvailable) {
      const { data: available } = await query
        .eq('status', 'active')
        .contains('marketa_multi_tenant_campaigns.participating_tenants', [context.tenantId])
        .or(`tenant_id.eq.${context.tenantId},campaign_type.eq.custom`);

      availableCampaigns = available || [];
    }

    // Get joined campaigns
    let joinedCampaigns = [];
    if (includeJoined) {
      const { data: joined } = await supabase
        .from('marketa_tenant_campaign_config')
        .select(`
          *,
          marketa_campaigns!inner(
            id,
            name,
            description,
            campaign_type,
            status,
            primary_cta,
            secondary_cta,
            sequence_length,
            helix_thread
          )
        `)
        .eq('tenant_id', context.tenantId)
        .in('status', ['joined', 'active', 'paused']);

      joinedCampaigns = joined || [];
    }

    return {
      success: true,
      available_campaigns: availableCampaigns,
      joined_campaigns: joinedCampaigns,
      total_available: availableCampaigns.length,
      total_joined: joinedCampaigns.length
    };
  },

