/**
 * LVB-AGQ Bridge API - Enhanced for Partner Platform
 * Provides comprehensive bridge endpoints for partner thin client operations
 * Supports WPP packs, custom campaigns, sequence campaigns, partner rewards, and Make integration
 */

import { NextRequest, NextResponse } from 'next/server';
import { createClient } from '@supabase/supabase-js';
import { crypto } from 'crypto';

// Initialize Supabase client
const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!
);

// Types for bridge operations
interface BridgeRequest {
  action: string;
  [key: string]: any;
}

interface PersonaContext {
  personaId: string;
  tenantId: string;
  role: string;
  permissions: string[];
}

// Helper functions
function getPersonaContext(request: NextRequest): PersonaContext {
  const personaId = request.headers.get('x-persona-id');
  const tenantId = request.headers.get('x-tenant-id');
  
  if (!personaId || !tenantId) {
    throw new Error('Missing persona identification headers');
  }

  // In a real implementation, you'd validate the persona and get their role/permissions
  return {
    personaId,
    tenantId,
    role: 'partnerAdmin', // This would come from CRM validation
    permissions: ['view_campaigns', 'join_campaigns', 'manage_packs', 'view_performance']
  };
}

function generateWebhookSignature(payload: string, secret: string): string {
  return crypto.createHmac('sha256', secret).update(payload).digest('hex');
}

async function validatePersonaAccess(personaId: string, tenantId: string): Promise<boolean> {
  // Validate persona belongs to tenant and has appropriate role
  const { data, error } = await supabase
    .from('crm_personas')
    .select('id, tenant_id, persona_state')
    .eq('id', personaId)
    .eq('tenant_id', tenantId)
    .single();

  return !error && data !== null;
}

