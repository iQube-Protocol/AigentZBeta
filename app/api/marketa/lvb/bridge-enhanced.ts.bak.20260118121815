  'join_campaign': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { campaignId, channels, startDate, timeOfDay, publishingMode, makeWebhookUrl, makeWebhookSecret } = body;

    if (!campaignId || !channels || !startDate) {
      throw new Error('Campaign ID, channels, and start date are required');
    }

    // Validate campaign exists and accepts participants
    const { data: campaign, error: campaignError } = await supabase
      .from('marketa_campaigns')
      .select('id, status, campaign_type, participating_tenants')
      .eq('id', campaignId)
      .single();

    if (campaignError || !campaign) {
      throw new Error('Campaign not found');
    }

    // Check if already joined
    const { data: existingConfig } = await supabase
      .from('marketa_tenant_campaign_config')
      .select('id')
      .eq('campaign_id', campaignId)
      .eq('tenant_id', context.tenantId)
      .single();

    if (existingConfig) {
      throw new Error('Already joined this campaign');
    }

    // Create tenant campaign config
    const { data: config, error } = await supabase
      .from('marketa_tenant_campaign_config')
      .insert({
        campaign_id: campaignId,
        tenant_id: context.tenantId,
        start_date: startDate,
        time_of_day: timeOfDay || '09:00',
        channels,
        publishing_mode: publishingMode || 'manual',
        make_webhook_url: makeWebhookUrl,
        make_webhook_secret: makeWebhookSecret,
        status: 'joined',
        joined_by_persona_id: context.personaId
      })
      .select()
      .single();

    if (error) throw error;

    // Log the join event
    await supabase.from('marketa_lvb_sync_tracking').insert({
      tenant_id: context.tenantId,
      sync_type: 'campaign_join',
      source_id: campaignId,
      sync_direction: 'lvb_to_agq',
      sync_status: 'success',
      data_payload: { campaignId, channels, publishingMode }
    });

    return {
      success: true,
      config,
      message: 'Successfully joined campaign'
    };
  },

