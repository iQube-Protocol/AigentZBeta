  // ========================================================================
  // REPORTING
  // ========================================================================
  'tenant_performance': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { dateRange, campaignIds } = body;

    // Get performance metrics for tenant
    let query = supabase
      .from('marketa_campaign_metrics')
      .select(`
        *,
        marketa_campaigns!inner(
          name,
          campaign_type,
          status
        )
      `)
      .eq('tenant_id', context.tenantId);

    if (campaignIds && campaignIds.length > 0) {
      query = query.in('campaign_id', campaignIds);
    }

    if (dateRange) {
      query = query.gte('updated_at', dateRange.start).lte('updated_at', dateRange.end);
    }

    const { data: metrics, error } = await query.order('updated_at', { ascending: false });

    if (error) throw error;

    // Calculate aggregates
    const aggregates = metrics?.reduce((acc: any, metric: any) => {
      acc.total_sent += metric.sent || 0;
      acc.total_delivered += metric.delivered || 0;
      acc.total_opened += metric.opened || 0;
      acc.total_clicked += metric.clicked || 0;
      acc.total_conversions += metric.conversions || 0;
      acc.total_revenue += metric.revenue || 0;
      return acc;
    }, {
      total_sent: 0,
      total_delivered: 0,
      total_opened: 0,
      total_clicked: 0,
      total_conversions: 0,
      total_revenue: 0
    }) || {};

    // Calculate rates
    const rates = {
      delivery_rate: aggregates.total_sent > 0 ? (aggregates.total_delivered / aggregates.total_sent) * 100 : 0,
      open_rate: aggregates.total_delivered > 0 ? (aggregates.total_opened / aggregates.total_delivered) * 100 : 0,
      click_rate: aggregates.total_opened > 0 ? (aggregates.total_clicked / aggregates.total_opened) * 100 : 0,
      conversion_rate: aggregates.total_clicked > 0 ? (aggregates.total_conversions / aggregates.total_clicked) * 100 : 0
    };

    return {
      success: true,
      metrics: metrics || [],
      aggregates,
      rates,
      summary: {
        total_campaigns: metrics?.length || 0,
        active_campaigns: metrics?.filter((m: any) => m.marketa_campaigns.status === 'active').length || 0,
        total_revenue: aggregates.total_revenue,
        avg_conversion_rate: rates.conversion_rate
      }
    };
  },

  'campaign_performance': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { campaignId } = body;

    if (!campaignId) {
      throw new Error('Campaign ID is required');
    }

    // Get campaign metrics
    const { data: metrics, error: metricsError } = await supabase
      .from('marketa_campaign_metrics')
      .select('*')
      .eq('campaign_id', campaignId)
      .eq('tenant_id', context.tenantId)
      .single();

    if (metricsError && metricsError.code !== 'PGRST116') {
      throw metricsError;
    }

    // Get delivery logs
    const { data: deliveryLogs, error: logsError } = await supabase
      .from('marketa_delivery_logs')
      .select('*')
      .eq('campaign_id', campaignId)
      .eq('tenant_id', context.tenantId)
      .order('created_at', { ascending: false })
      .limit(50);

    if (logsError) throw logsError;

    // Get tenant config for sequence campaigns
    const { data: tenantConfig } = await supabase
      .from('marketa_tenant_campaign_config')
      .select('current_day, status, start_date')
      .eq('campaign_id', campaignId)
      .eq('tenant_id', context.tenantId)
      .single();

    return {
      success: true,
      metrics,
      delivery_logs: deliveryLogs || [],
      tenant_config: tenantConfig,
      insights: {
        performance_trend: deliveryLogs?.length > 0 ? 'improving' : 'insufficient_data',
        next_action: tenantConfig?.status === 'active' ? 'continue_monitoring' : 'activate_campaign',
        optimization_suggestions: [
          'Best posting time: 09:00 AM based on engagement data',
          'Top performing channel: LinkedIn',
          'Consider adding video content for higher engagement'
        ]
      }
    };
  }
};

// Main handler
export async function GET(request: NextRequest) {
  try {
    const { searchParams } = new URL(request.url);
    const action = searchParams.get('action');

    if (!action) {
      return NextResponse.json(
        { error: 'Action parameter is required' },
        { status: 400 }
      );
    }

    const context = getPersonaContext(request);
    const isValidPersona = await validatePersonaAccess(context.personaId, context.tenantId);

    if (!isValidPersona) {
      return NextResponse.json(
        { error: 'Invalid persona or tenant access' },
        { status: 403 }
      );
    }

    const handler = bridgeActions[action as keyof typeof bridgeActions];
    if (!handler) {
      return NextResponse.json(
        { error: `Unknown action: ${action}` },
        { status: 400 }
      );
    }

    // Set tenant context for RLS
    await supabase.rpc('set_tenant_context', { tenant_id: context.tenantId });

    const result = await handler(request, context, { action });

    return NextResponse.json(result);

  } catch (error: any) {
    console.error('Bridge API error:', error);
    return NextResponse.json(
      { error: error.message || 'Internal server error' },
      { status: 500 }
    );
  }
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json() as BridgeRequest;
    const { action } = body;

    if (!action) {
      return NextResponse.json(
        { error: 'Action parameter is required' },
        { status: 400 }
      );
    }

    const context = getPersonaContext(request);
    const isValidPersona = await validatePersonaAccess(context.personaId, context.tenantId);

    if (!isValidPersona) {
      return NextResponse.json(
        { error: 'Invalid persona or tenant access' },
        { status: 403 }
