  // ========================================================================
  // PARTNER SETTINGS
  // ========================================================================
  'webhook_test': async (request: NextRequest, context: PersonaContext, body: BridgeRequest) => {
    const { makeWebhookUrl, makeWebhookSecret } = body;

    if (!makeWebhookUrl) {
      throw new Error('Webhook URL is required');
    }

    // Create test payload
    const testPayload = {
      test: true,
      timestamp: new Date().toISOString(),
      tenant_id: context.tenantId,
      campaign_id: 'test-campaign',
      sequence_item: {
        day_number: 1,
        title: 'Test Webhook Payload',
        asset_ref: 'test-asset'
      }
    };

    const payloadString = JSON.stringify(testPayload);
    const signature = makeWebhookSecret 
      ? generateWebhookSignature(payloadString, makeWebhookSecret)
      : null;

    // Send test webhook
    const startTime = Date.now();
    let responseCode = 0;
    let responseBody = '';
    let errorMessage = '';

    try {
      const response = await fetch(makeWebhookUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(signature && { 'X-Webhook-Signature': signature })
        },
        body: payloadString
      });

      responseCode = response.status;
      responseBody = await response.text();
    } catch (error: any) {
      errorMessage = error.message;
    }

    const responseTime = Date.now() - startTime;
    const testStatus = responseCode >= 200 && responseCode < 300 ? 'success' : 'failed';

    // Log the test result
    await supabase.from('marketa_webhook_tests').insert({
      tenant_id: context.tenantId,
      webhook_url: makeWebhookUrl,
      webhook_secret: makeWebhookSecret,
      test_status: testStatus,
      response_code: responseCode,
      response_body: responseBody,
      response_time_ms: responseTime,
      error_message: errorMessage,
      test_payload: testPayload,
      signature_header: signature,
      tested_by_persona_id: context.personaId
    });

    return {
      success: true,
      test_result: {
        status: testStatus,
        response_code: responseCode,
        response_time_ms: responseTime,
        error_message: errorMessage
      },
      message: testStatus === 'success' 
        ? 'Webhook test successful' 
        : `Webhook test failed: ${errorMessage || 'HTTP ' + responseCode}`
    };
  },

