# ClawHack Group Agents - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# Tenant Configuration
# ============================================================================
QT_TENANT_ID=tnt_clawhack
QT_CHANNEL_MAIN=clawhack

# ============================================================================
# XMTP Configuration (for XMTP adapter)
# ============================================================================
# Comma-separated list of allowed XMTP group IDs
XMTP_GROUP_ID_ALLOWLIST=group_abc123,group_xyz789

# Encryption key for local XMTP DB (if using libxmtp with local storage)
XMTP_DB_ENCRYPTION_KEY=your_encryption_key_here

# XMTP environment (dev, production)
XMTP_ENV=dev

# Current adapter path is simulation-only unless full XMTP SDK wiring is added
XMTP_SIMULATION_MODE=true

# ============================================================================
# Discord Configuration
# ============================================================================
# Discord bot token (get from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional Discord webhook URL for publish-only mode (used if bot token is absent)
DISCORD_WEBHOOK_URL=

# Discord channel ID(s) to monitor (comma-separated)
DISCORD_METAKNYTS_CHANNEL_ID=1234567890123456789

# ============================================================================
# MCP Registry Configuration
# ============================================================================
# MCP Registry endpoint for tool discovery
MCP_REGISTRY_ENDPOINT=http://localhost:8080/registry

# Shelf ID for ClawHack curated tools
MCP_SHELF_ID=shelf_clawhack_2026_group_agents

# ============================================================================
# DVN Receipts Configuration
# ============================================================================
# DVN receipts endpoint (QubeTalk topic or HTTP endpoint)
DVN_ENDPOINT=qt://tnt_clawhack/clawhack/dvn/receipts

# Enable DVN receipt emission (true/false)
DVN_RECEIPTS_ENABLED=true

# ============================================================================
# A2UI/Surface Planner Integration
# ============================================================================
# Surface Planner endpoint for deterministic capsule design
SURFACE_PLANNER_ENDPOINT=http://localhost:3000/api/metame/runtime/plan

# Enable Surface Planner for Discord capsules (true/false)
SURFACE_PLANNER_ENABLED=true

# ============================================================================
# OpenClaw Configuration
# ============================================================================
# OpenClaw agent endpoint
OPENCLAW_ENDPOINT=http://localhost:8081/openclaw

# OpenClaw allowlist enforcement (true/false)
OPENCLAW_ALLOWLIST_ENABLED=true

# Required curated tools that must exist before runtime starts
OPENCLAW_REQUIRED_TOOLS=knyt.comic.generate_pack,dpr.run

# Enforce required tool availability as a hard failure (defaults to true in prod)
OPENCLAW_REQUIRED_TOOLS_STRICT=false

# Require remote registry source (recommended true in production)
OPENCLAW_REQUIRE_REMOTE_REGISTRY=false

# Allow synthetic stub tool results if MCP tool calls fail (default false for production)
OPENCLAW_ALLOW_STUB_RESULTS=false

# Allow fallback registry tools if MCP registry is unavailable (default false for production)
OPENCLAW_ALLOW_REGISTRY_FALLBACK=false

# OpenClaw MCP invoke timeout in ms
OPENCLAW_MCP_TIMEOUT_MS=12000

# OpenClaw local data path for ConversationQubes and artifacts
OPENCLAW_DATA_DIR=.data

# ============================================================================
# QubeTalk Configuration
# ============================================================================
# QubeTalk API endpoint
QUBETALK_API_ENDPOINT=http://localhost:3000/api/qubetalk

# QubeTalk authentication token
QUBETALK_AUTH_TOKEN=your_qubetalk_token_here

# Optional explicit channel IDs (if omitted, runtime reads .data/channel-map.json)
QT_CHANNEL_MAIN_ID=
QT_CHANNEL_BRIDGE_INBOUND_ID=
QT_CHANNEL_BRIDGE_OUTBOUND_ID=
QT_CHANNEL_OPENCLAW_REQUESTS_ID=
QT_CHANNEL_OPENCLAW_RESPONSES_ID=
QT_CHANNEL_ROUTER_ID=
QT_CHANNEL_DVN_RECEIPTS_ID=

# Group runtime polling interval (ms)
GROUP_RUNTIME_POLL_MS=4000

# ============================================================================
# Environment
# ============================================================================
# Environment: hackathon, dev, staging, prod
ENVIRONMENT=hackathon

# Log level: debug, info, warn, error
LOG_LEVEL=info
