{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AigentZBeta/.claude/hooks/scripts/check-prompt-safety.sh \"$CLAUDE_PROMPT\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AigentZBeta/.claude/hooks/scripts/block-dangerous-commands.sh \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AigentZBeta/.claude/hooks/scripts/post-edit-check.sh \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AigentZBeta/.claude/hooks/scripts/session-summary.sh"
          }
        ]
      }
    ]
  }
}
