{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiq.example/schemas/retrieval_index.schema.json",
  "title": "Agentiq Cartridge Retrieval Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "repo", "entries"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "repo": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "type", "title", "tags", "last_updated"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "components": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "endpoints": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "owners": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "related": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}
