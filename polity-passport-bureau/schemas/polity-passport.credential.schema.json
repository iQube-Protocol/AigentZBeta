{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metame.com/polity/passport/v0.1/polity-passport.credential.schema.json",
  "title": "Polity Passport Credential",
  "type": "object",
  "required": [
    "schema_version",
    "passport_id",
    "passport_type",
    "passport_status",
    "holder",
    "issued_at",
    "issuer",
    "registry_record"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "passport_id": {
      "type": "string",
      "minLength": 1
    },
    "passport_type": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/passportType"
    },
    "passport_status": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/passportStatus"
    },
    "passport_grade": {
      "type": "string",
      "enum": [
        "anonymous_citizen",
        "pseudonymous_citizen",
        "verified_anonymous_citizen",
        "verified_pseudonymous_citizen",
        "identifiable_citizen",
        "provisional_participant",
        "restricted_participant",
        "approved_participant",
        "steward_reviewed_participant"
      ]
    },
    "holder": {
      "type": "object",
      "properties": {
        "holder_kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "robot",
            "organization_agent",
            "model_backed_service"
          ]
        },
        "persona": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/personaRef"
        },
        "kybe_did": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/didRef"
        },
        "root_did": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/didRef"
        },
        "agent_card_url": {
          "type": "string",
          "format": "uri"
        },
        "agent_iqube_ref": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/qubeRef"
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "properties": {
        "rights": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/policyConstraint"
          },
          "uniqueItems": true
        },
        "obligations": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/policyObligation"
          },
          "uniqueItems": true
        },
        "permitted_domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "issuer": {
      "type": "object",
      "required": [
        "issuer_id",
        "issuer_name"
      ],
      "properties": {
        "issuer_id": {
          "type": "string"
        },
        "issuer_name": {
          "type": "string",
          "default": "Polity Passport Bureau"
        },
        "issuer_did": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/didRef"
        },
        "issuer_signature": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "registry_record": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/qubeRef"
    },
    "application_ref": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/qubeRef"
    },
    "reputation_binding_ref": {
      "type": "string",
      "description": "Reference to the passport's reputation binding record."
    },
    "citizen_irrevocability": {
      "type": "object",
      "properties": {
        "applies_to_citizen_passport": {
          "type": "boolean"
        },
        "personhood_recognition_irrevocable": {
          "type": "boolean"
        },
        "reputation_can_revoke_passport": {
          "const": false
        },
        "reputation_can_restrict_privileges": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "issued_at": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/isoDatetime"
    },
    "expires_at": {
      "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/isoDatetime"
    },
    "renewal_of_passport_id": {
      "type": "string"
    },
    "revocation": {
      "type": "object",
      "$comment": "Applies to participant-class passports only. Citizen passports are irrevocable (PRD Addendum D); the per-class conditional below forbids citizen revoked status.",
      "properties": {
        "revoked": {
          "type": "boolean",
          "default": false
        },
        "revoked_at": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/isoDatetime"
        },
        "revocation_reason": {
          "type": "string"
        },
        "revocation_receipt": {
          "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/receiptRef"
        }
      },
      "additionalProperties": false
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/receiptRef"
      }
    }
  },
  "allOf": [
    {
      "$comment": "Per-class status enforcement (PRD Addendum D): citizen passports use the citizen lifecycle enum (no revoked); participant passports use the participant standing enum.",
      "if": {
        "properties": {
          "passport_type": {
            "enum": [
              "citizen",
              "verified_citizen"
            ]
          }
        },
        "required": [
          "passport_type"
        ]
      },
      "then": {
        "properties": {
          "passport_status": {
            "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/citizenPassportStatus"
          },
          "revocation": {
            "properties": {
              "revoked": {
                "const": false
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "passport_status": {
            "$ref": "https://schemas.metame.com/polity/passport/v0.1/common.schema.json#/$defs/participantPassportStatus"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
