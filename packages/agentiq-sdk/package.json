{
  "name": "@agentiq/agentiq-sdk",
  "version": "0.1.0",
  "description": "AgentiQ OS developer SDK — AA-API client, A2A protocol, registry, persona, delegation, and CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agentiq": "./bin/agentiq.js"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "cli": "node bin/agentiq.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "agentiq",
    "agentiq-os",
    "aa-api",
    "a2a",
    "sdk",
    "iqube",
    "aigent",
    "delegation",
    "cartridge"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "author": "iQube Protocol",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/iQube-Protocol/AgentiQ-OS"
  }
}
