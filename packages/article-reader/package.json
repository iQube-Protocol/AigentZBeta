{
  "name": "@agentiq/article-reader",
  "version": "0.1.0",
  "description": "Franchise-styled article reader with markdown rendering",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
