{
  "manifest_version": 3,
  "name": "metaMe Companion — Constitutional Observer",
  "version": "0.1.0",
  "description": "PRD-MMC-IMPL-001 Increment 6 / PRD-MMC-IMPL-003 Increment 4: consent-gated browser context Observer + Capture (\"Pull Across\") for the metaMe Companion. Reads and captures only what a persona has explicitly granted (types/companionObserver.ts, types/companionCapture.ts) and hands it to the Companion API — never a raw page dump.",
  "key": "",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "contextMenus"],
  "host_permissions": [
    "https://dev-beta.aigentz.me/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["constants.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "metaMe Companion Observer"
  }
}
