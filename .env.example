# Aigent Z Configuration Example

# Next.js Environment Variables
NODE_ENV=development

# API URLs and Keys
# Core API Configuration
NEXT_PUBLIC_CORE_API_URL=http://localhost:8000
CORE_API_KEY=your_api_key_here

# Registry API Configuration
NEXT_PUBLIC_REGISTRY_API_URL=http://localhost:8001
REGISTRY_API_KEY=your_registry_api_key_here

# Aigent Configuration
NEXT_PUBLIC_AIGENT_API_URL=http://localhost:8002
AIGENT_API_KEY=your_aigent_api_key_here

# Blockchain Configuration
NEXT_PUBLIC_WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
NEXT_PUBLIC_DEFAULT_NETWORK=ethereum

# AI Model Configurations
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-1
ANTHROPIC_API_KEY=your_anthropic_api_key
VENICE_API_KEY=your_venice_api_key
VENICE_IMAGE_MODEL=venice-sd35
SUPABASE_STORAGE_BUCKET=assets
NEXT_PUBLIC_RUNTIME_IFRAME_URL=https://runtime.metame.com/metame/runtime?embed=1&shell=thin
NEXT_PUBLIC_RUNTIME_IFRAME_ORIGIN=https://runtime.metame.com
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VOYAGE_API_KEY=your_voyage_api_key_optional
VOYAGE_EMBEDDING_MODEL=voyage-large-2

# iQube Registry Configuration
NEXT_PUBLIC_IQUBE_REGISTRY_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_BLAKQUBE_STORAGE_ENDPOINT=https://ipfs.io/ipfs/

# Security Settings
ENCRYPTION_KEY=generate_a_secure_random_key_here
NEXT_PUBLIC_TOKEN_EXPIRATION_HOURS=24

# Development Flags
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_TESTING=false

# iQubeNFT — ERC721 on-chain anchor (contracts/iQubeNFT.sol)
# Chain: 84532 = Base Sepolia (testnet), 8453 = Base mainnet
IQUBE_NFT_CONTRACT_ADDRESS=
IQUBE_NFT_CHAIN_ID=84532
IQUBE_NFT_RPC_URL=
# Server-side deployer key — NEVER prefix with NEXT_PUBLIC_
EVM_DEPLOYER_KEY=

# Ethereum mainnet RPC — used for $KNYT balance reads and minting (chainId 1)
# Free options: https://eth.llamarpc.com (public), or Alchemy/Infura for production
ETH_RPC_URL=

# External Wallet Connect (WalletConnect / Reown)
# Get a free project ID at https://cloud.reown.com — create a project, copy the ID
# Without this, only browser-extension wallets (MetaMask etc.) will be available
NEXT_PUBLIC_REOWN_PROJECT_ID=

# KNYT Treasury — EVM address that receives $KNYT payments from external wallets
# Set to the treasury / Know1 EVM address that holds incoming $KNYT
NEXT_PUBLIC_KNYT_TREASURY_ADDRESS=

# KNYT Token Contract on Base mainnet (read-only — do not change)
NEXT_PUBLIC_KNYT_CONTRACT_ADDRESS=0xe53dad36cd0A8EdC656448CE7912bba72beBECb4

# BTC / ICP Canister Integration
BTC_CUSTODY_ENABLED=false
BTC_NETWORK=testnet
BTC_CUSTODIAN_KEY_REF=
BTC_SIGNER_CANISTER_ID=

# Optional External Service Integrations
TAVILY_API_KEY=your_tavily_api_key_optional

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
