# =============================================
# BLOCKCHAIN RPC ENDPOINTS
# =============================================

# Bitcoin Testnet RPC
NEXT_PUBLIC_RPC_BTC_TESTNET=https://mempool.space/testnet/api

# Ethereum Sepolia RPC (for Infura or other provider)
NEXT_PUBLIC_RPC_ETH_SEPOLIA=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Polygon Amoy RPC
NEXT_PUBLIC_RPC_POLYGON_AMOY=https://rpc-amoy.polygon.technology

# Optimism Sepolia RPC
NEXT_PUBLIC_RPC_OPTIMISM_SEPOLIA=https://sepolia.optimism.io

# Arbitrum Sepolia RPC  
NEXT_PUBLIC_RPC_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc

# Base Sepolia RPC
NEXT_PUBLIC_RPC_BASE_SEPOLIA=https://sepolia.base.org

# =============================================
# APPLICATION CONFIGURATION
# =============================================

# Next.js Configuration
NODE_ENV=development
NEXT_PUBLIC_NODE_ENV=development

# Application Port
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/iQube

# Redis Configuration (if used)
REDIS_URL=redis://localhost:6379

# JWT Secret (for authentication)
JWT_SECRET=your-jwt-secret-key-here

# Encryption Keys
ENCRYPTION_KEY=your-32-character-encryption-key

# Dev User ID
DEV_USER_ID=2b279043-03cf-416f-af5f-d5dee03c74e1

# =============================================
# DEVELOPMENT & DEBUGGING
# =============================================

# Debug Mode
DEBUG=true
NEXT_PUBLIC_DEBUG=true

# Logging Level
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================
# EXTERNAL API KEYS
# =============================================

# Infura (for Ethereum RPC)
INFURA_PROJECT_ID=your-infura-project-id
INFURA_PROJECT_SECRET=your-infura-secret

# Alchemy (alternative to Infura)
ALCHEMY_API_KEY=your-alchemy-api-key

# BlockCypher (Bitcoin API)
BLOCKCYPHER_API_TOKEN=your-blockcypher-token

# LayerZero Configuration
LAYERZERO_ENDPOINT_V2=your-layerzero-endpoint

# =============================================
# BLOCKCHAIN API KEYS (FOR CONTRACT DEPLOYMENT)
# =============================================

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your-etherscan-api-key-here

# PolygonScan API Key (for contract verification)
POLYGONSCAN_API_KEY=your-polygonscan-api-key-here

# Arbiscan API Key (for contract verification)
ARBISCAN_API_KEY=your-arbiscan-api-key-here

# BaseScan API Key (for contract verification)
BASESCAN_API_KEY=your-basescan-api-key-here

# Optimism API Key (for contract verification)
OPTIMISM_API_KEY=your-optimism-api-key-here

# Deployment Private Key (without 0x prefix)
PRIVATE_KEY=your-deployment-private-key-here

# =============================================
# WALLET CONFIGURATION
# =============================================

# Wallet Connect Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# MetaMask Configuration
METAMASK_DAPP_ID=your-metamask-dapp-id

# =============================================
# MONITORING & ANALYTICS
# =============================================

# Sentry DSN (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=GA-TRACKING-ID

# =============================================
# DEPLOYMENT CONFIGURATION
# =============================================

# Build Configuration
BUILD_ENV=development

# CDN Configuration (if using)
CDN_URL=https://cdn.yourdomain.com

# Asset Optimization
NEXT_PUBLIC_ENABLE_COMPRESSION=true

# =============================================
# SECURITY CONFIGURATION
# =============================================

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# CSRF Protection
CSRF_SECRET=your-csrf-secret-key

# Session Configuration
SESSION_SECRET=your-session-secret-key

# =============================================
# FEATURE FLAGS
# =============================================

# Enable/disable specific features
NEXT_PUBLIC_ENABLE_TESTNET=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# =============================================
# PERFORMANCE CONFIGURATION
# =============================================

# Cache Configuration
CACHE_TTL=3600
NEXT_PUBLIC_CACHE_TTL=3600

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================
# LOCAL DEVELOPMENT OVERRIDES
# =============================================

# Override canister host for local development
# ICP_HOST=http://127.0.0.1:4943
# NEXT_PUBLIC_ICP_HOST=http://127.0.0.1:4943

# =============================================
# PRODUCTION DEPLOYMENT
# =============================================

# For production deployment, ensure these are set:
# - All canister IDs point to production canisters
# - Supabase credentials are production values
# - RPC endpoints are production-ready
# - Security keys are properly configured
# - NODE_ENV=production
# - NEXT_PUBLIC_NODE_ENV=production

# =============================================
# NOTES
# =============================================
# 1. Never commit .env.local to version control
# 2. Use different values for development vs production
# 3. Keep sensitive keys secure and rotate regularly
# 4. Test environment variables after any changes
# 5. Use strong, unique values for all secrets
